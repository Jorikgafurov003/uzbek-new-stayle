        "photo": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "agent_id": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["name", "phone", "role", "password"]
    }
  },
