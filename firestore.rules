rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Функция проверки авторизации
    function isAuthenticated() {
      return request.auth != null;
    }

    // Функция проверки владения документом (по ID документа или полю uid)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Правила для коллекции пользователей: каждый видит и редактирует только себя
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Заказы: доступ только если пользователь является клиентом, агентом или курьером в этом заказе
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.clientId || 
        request.auth.uid == resource.data.agentId || 
        request.auth.uid == resource.data.courierId
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.agentId || 
        request.auth.uid == resource.data.courierId
      );
    }

    // Долги: только владелец долга может видеть его
    match /debts/{debtId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.clientId;
      allow write: if false; // Только системные процессы или админ (через бэкенд) могут менять долги
    }

    // Зарплаты: только владелец видит свою зарплату
    match /salaries/{salaryId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // Настройки кофигурации зарплаты: только владелец
    match /user_salary_config/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // Продукты, категории и баннеры: читать могут все авторизованные, писать — никто (через Firestore напрямую)
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /banners/{bannerId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /settings/{settingKey} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Запрет доступа ко всем остальным данным по умолчанию
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
