{
  "name": "react-example",
  "private": true,
  "version": "1.0.0",
  "main": "electron-main.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx src/backend/server.ts",
    "build:frontend": "vite build",
    "build:backend": "tsc -p src/backend/tsconfig.json",
    "build": "npm run build:frontend && npm run build:backend",
    "preview": "vite preview",
    "start": "node dist-backend/backend/server.js",
    "clean": "rm -rf dist dist-backend",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "android:init": "cap init Uzbechka com.uzbechka.app --web-dir dist",
    "android:sync": "npm run build && cap copy android && cap sync android",
    "android:open": "cap open android",
    "electron:pack": "electron-builder build --win --publish never"
  },
  "build": {
    "appId": "com.uzbechka.app",
    "productName": "Uzbechka",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "server.ts",
      "package.json",
      "uzbechka.db"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@capacitor/ios": "^8.1.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet-routing-machine": "^3.2.9",
    "@types/mapbox-gl": "^3.4.1",
    "@types/multer": "^2.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.18.0",
    "@vis.gl/react-google-maps": "^1.7.1",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "lucide-react": "^0.546.0",
    "mapbox-gl": "^3.19.1",
    "maplibre-gl": "^5.19.0",
    "motion": "^12.23.24",
    "multer": "^2.1.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
